# Copie para .env e ajuste. Projeto local/single-user (Handoff §13, com desvios
# do PLAN.md: sem auth, acesso só em localhost).
DEBUG=1
SECRET_KEY=troque-por-uma-chave-secreta-qualquer
DATABASE_URL=postgres://planejador:dev@db:5432/planejador
REDIS_URL=redis://redis:6379/0
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Origem local do frontend (Vite=5173, CRA/Next=3000).
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
DJANGO_SETTINGS_MODULE=config.settings
# Planejamento assistido por IA (Ollama local — Fase A). IA_PLANEJAMENTO_ENABLED=0
# desliga a IA (entrega só o plano base do solver).
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_TIMEOUT=300
IA_PLANEJAMENTO_ENABLED=1
# Calibração da estimativa de tempo do plano (opcionais; têm default no settings).
# PLANEJAR_TEMPO_BASE_S=55
# PLANEJAR_TEMPO_POR_TAREFA_S=3
